{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A high score entry on the global leaderboard",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the player" },
        "username": { "type": "string", "description": "The display name of the player" },
        "score": { "type": "integer", "description": "The high score achieved" },
        "difficulty": { "type": "string", "enum": ["EASY", "NORMAL", "HARD"], "description": "The difficulty level used" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the score was achieved" }
      },
      "required": ["userId", "username", "score", "difficulty", "timestamp"]
    }
  },
  "firestore": {
    "/leaderboard/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Collection of global high scores"
    }
  }
}
